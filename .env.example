# ============================================================
# Variational AI Agent System - 환경변수 설정
# ============================================================
# 이 파일은 템플릿입니다. 실제 사용 시:
# 1. 이 파일을 복사하여 .env로 저장: cp .env.example .env
# 2. YOUR_..._HERE 부분을 실제 값으로 교체
# 3. .env 파일은 절대 Git에 올리지 마세요
# ============================================================

# --- Claude API (필수) ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# --- Telegram Bot (필수: 결과 전송용) ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# 채널 ID (필수: 각 LINE별 채널)
TG_CHANNEL_URGENT=YOUR_URGENT_CHANNEL_ID_HERE
TG_CHANNEL_MARKET=YOUR_MARKET_CHANNEL_ID_HERE
TG_CHANNEL_CONTENT=YOUR_CONTENT_CHANNEL_ID_HERE
TG_CHANNEL_PERFORMANCE=YOUR_PERFORMANCE_CHANNEL_ID_HERE
TG_CHANNEL_QA_MARKETING=YOUR_QA_MARKETING_CHANNEL_ID_HERE

# --- Telegram API (필수: 데이터 수집용) ---
# https://my.telegram.org 에서 발급
TELEGRAM_API_ID=YOUR_TELEGRAM_API_ID_HERE
TELEGRAM_API_HASH=YOUR_TELEGRAM_API_HASH_HERE

# --- Email (선택: POC Agent 상사 이메일 발송, 추후 구현) ---
EMAIL_SMTP_HOST=YOUR_SMTP_HOST_HERE
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=YOUR_EMAIL_HERE
EMAIL_PASSWORD=YOUR_EMAIL_PASSWORD_HERE
EMAIL_RECIPIENT=YOUR_BOSS_EMAIL_HERE

# --- X/Twitter (선택: 추후 구현) ---
X_BEARER_TOKEN=YOUR_X_BEARER_TOKEN_HERE

# --- Discord (선택: 추후 구현) ---
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# --- Apify (선택: 추후 구현) ---
APIFY_API_TOKEN=YOUR_APIFY_API_TOKEN_HERE

# --- CoinMarketCap (선택: 추후 구현) ---
CMC_API_KEY=YOUR_COINMARKETCAP_API_KEY_HERE

# --- SurfAI (선택: 소셜 영향력/KOL 분석) ---
# https://asksurf.ai 에서 API 키 발급
SURF_API_KEY=YOUR_SURF_API_KEY_HERE
